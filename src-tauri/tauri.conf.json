{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Popup Bar",
  "version": "0.1.0",
  "identifier": "com.popupbar.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:",
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/skins/**"]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "Popup Bar",
        "width": 640,
        "height": 72,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "dragDropEnabled": true,
        "x": 0,
        "y": 0
      }
    ]
  },
  "bundle": {
    "publisher": "Popup Bar Contributors",
    "category": "Utility",
    "shortDescription": "Popup launcher bar with hotzone trigger and persistent shelf items.",
    "longDescription": "Popup Bar is a desktop launcher built with Tauri that reveals itself from the screen edge, stores pinned files and apps in SQLite, and ships with a production MSI build flow.",
    "copyright": "Copyright (c) 2026 Popup Bar Contributors",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "useLocalToolsDir": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": ["msi", "dmg", "appimage", "deb"],
    "windows": {
      "wix": {
        "upgradeCode": "f9945b89-3d67-564d-ac2d-5ef406e4c7dd",
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:popup-bar.db"
      ]
    },
    "shell": {
      "open": true
    }
  }
}
