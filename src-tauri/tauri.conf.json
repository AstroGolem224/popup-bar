{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Popup Bar",
  "version": "0.1.0",
  "identifier": "com.popup-bar.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost"
    },
    "windows": [
      {
        "title": "Popup Bar",
        "width": 640,
        "height": 72,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "resizable": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "dragDropEnabled": true,
        "x": 0,
        "y": 0
      }
    ]
  },
  "bundle": {
    "icon": [
      "icons/icon.ico"
    ],
    "targets": ["msi", "dmg", "appimage", "deb"]
  },
  "plugins": {
    "sql": {
      "preload": [
        "sqlite:popup-bar.db"
      ]
    },
    "shell": {
      "open": true
    }
  }
}
